
import time

nome = input("Olá novo usuário, qual seu nome?: ")
print("olá,", nome)

#senha normal

senha = input("crie uma senha: ")
        
#verificador de digitos na senha
while True:
        
    if len(senha) == 6:
        print("senha valida")
        break
    else:
        print("a senha deve conter 6 digitos")
    senha = input("crie a senha com 6 digitos: ")


# tentativas
time.sleep(0.6)
tentativas = 0

while tentativas <=3:
    usuario= input("digite sua senha para entrar: ")
    tentativas += 1
    
    if usuario == senha:
        print("senha correta")
        print("✅ voce acertou em,", tentativas,"tentativa(s)")
        break
        
    else:
        print("❌ senha incorreta, tente novamente")
        
        if tentativas == 3 and usuario != senha:
            print("🚫 conta bloqueada")
            

        

